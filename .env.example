# -----------------------------
# Core server
# -----------------------------
NODE_ENV=development
PORT=5000

# -----------------------------
# API keys / AI
# -----------------------------
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=600
AI_LOG_RETENTION_DAYS=30

# -----------------------------
# Redis
# -----------------------------
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TLS=false

# -----------------------------
# Queue system (BullMQ)
# -----------------------------
JOB_QUEUE_ENABLED=true

# Insight generation queue
INSIGHT_QUEUE_ENABLED=true
INSIGHT_QUEUE_ATTEMPTS=3
INSIGHT_QUEUE_BACKOFF_MS=1500
INSIGHT_WORKER_CONCURRENCY=4
# Unlock endpoint waits this long before returning pending job state
INSIGHT_QUEUE_WAIT_MS=18000

# Outcome grading queue
OUTCOME_QUEUE_ENABLED=true
OUTCOME_QUEUE_ASYNC=true
OUTCOME_QUEUE_ATTEMPTS=4
OUTCOME_QUEUE_BACKOFF_MS=2000
OUTCOME_WORKER_CONCURRENCY=3

# Scoring queue
SCORING_QUEUE_ENABLED=true
SCORING_QUEUE_ATTEMPTS=3
SCORING_QUEUE_BACKOFF_MS=1500
SCORING_WORKER_CONCURRENCY=2

# -----------------------------
# Stats snapshot / scoring tuning
# -----------------------------
PLAYER_STATS_SNAPSHOT_TTL_SECONDS=21600
SCORE_BULK_BATCH_SIZE=300
SOCCER_LEAGUE_FETCH_CONCURRENCY=3
SOCCER_PROP_WATCHER_CONCURRENCY=6

# -----------------------------
# Cron toggles / schedules
# -----------------------------
CRON_MORNING_SCRAPER_ENABLED=true
CRON_MORNING_SCRAPER_SCHEDULE=0 8 * * *

CRON_PROP_WATCHER_ENABLED=true
CRON_PROP_WATCHER_SCHEDULE=2,32 * * * *

CRON_POST_GAME_SYNC_ENABLED=true
CRON_POST_GAME_SYNC_SCHEDULE=5,20,35,50 * * * *
CRON_POST_GAME_CLEANUP_SCHEDULE=0 3 * * *

CRON_INJURY_REFRESH_ENABLED=false
CRON_INJURY_REFRESH_SCHEDULE=1-59/5 * * * *
INJURY_REFRESH_LOOKAHEAD_MINUTES=90
INJURY_REFRESH_STALE_MINUTES=30

# -----------------------------
# Data retention / cleanup
# -----------------------------
GRADED_RETENTION_DAYS=45
RETRY_EXHAUSTED_PRUNE_DAYS=14
